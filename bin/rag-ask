#!/usr/bin/env bash
# Usage: bin/rag-ask "Spring Bean이 뭐야?" [--repo <name>]
# Output: JSON {decision, hits, next_command}
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -n "${PYTHON:-}" ]]; then
  PY="$PYTHON"
elif [[ -x "$ROOT/.venv/bin/python" ]]; then
  PY="$ROOT/.venv/bin/python"
else
  PY="python3"
fi
exec "$PY" "$ROOT/scripts/workbench/cli.py" rag-ask "$@"
