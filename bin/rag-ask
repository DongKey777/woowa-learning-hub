#!/usr/bin/env bash
# Usage: bin/rag-ask "Spring Bean이 뭐야?" [--repo <name>] [--reformulated-query "..."]
# Output: JSON {decision, hits, next_command}
#
# Daemon mode is the default — the wrapper appends --via-daemon so the
# learner-side BGE-M3 + reranker stays warm across calls (cold ~25s,
# warm ~1.3s). The daemon auto-spawns on first request via
# ensure_daemon().
#
# Production R3 env defaults are sourced from bin/_rag_env.sh so an AI
# session that forgets the AGENTS.md contract still gets the 95.5%
# Pilot baseline behaviour. Override in the calling shell when
# intentional.
#
# Opt-out:
#   WOOWA_RAG_NO_DAEMON=1 bin/rag-ask "..."   # skip --via-daemon (CI / debug)
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -n "${PYTHON:-}" ]]; then
  PY="$PYTHON"
elif [[ -x "$ROOT/.venv/bin/python" ]]; then
  PY="$ROOT/.venv/bin/python"
else
  PY="python3"
fi

# shellcheck disable=SC1091
source "$ROOT/bin/_rag_env.sh"

CMD=("$PY" "$ROOT/scripts/workbench/cli.py" "rag-ask")
if [[ "${WOOWA_RAG_NO_DAEMON:-0}" != "1" ]]; then
  CMD+=("--via-daemon")
fi

exec "${CMD[@]}" "$@"
