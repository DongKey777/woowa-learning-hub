#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -n "${PYTHON:-}" ]]; then
  PY="$PYTHON"
elif [[ -x "$ROOT/.venv/bin/python" ]]; then
  PY="$ROOT/.venv/bin/python"
else
  PY="python3"
fi

# shellcheck disable=SC1091
source "$ROOT/bin/_rag_env.sh"

exec "$PY" "$ROOT/scripts/learning/cli_cs_index_build.py" "$@"
