{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ComparePacket",
  "type": "object",
  "required": [
    "packet_type",
    "repo",
    "prs",
    "generated",
    "source_db_path",
    "pr_summary",
    "review_density",
    "path_hotspots",
    "representative_comments",
    "evidence"
  ],
  "properties": {
    "packet_type": { "const": "compare" },
    "repo": { "type": "string" },
    "prs": { "type": "array", "items": { "type": "integer" } },
    "generated": { "type": "boolean" },
    "source_db_path": { "type": "string" },
    "markdown_path": { "type": ["string", "null"] },
    "markdown_preview": { "type": "array" },
    "error": { "type": ["string", "null"] },
    "pr_summary": { "type": "array" },
    "review_density": { "type": "array" },
    "path_hotspots": { "type": "array" },
    "representative_comments": { "type": "array" },
    "evidence": { "type": "object" },
    "generated_at": { "type": "string" }
  }
}
