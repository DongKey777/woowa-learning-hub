{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearningMemorySummary",
  "type": "object",
  "required": [
    "summary_type",
    "repo",
    "updated_at",
    "total_sessions",
    "top_topics",
    "top_intents",
    "top_learning_points",
    "repeated_learning_points",
    "learning_point_confidence",
    "top_reviewers",
    "recurring_paths",
    "recent_questions",
    "recent_learning_points",
    "repeated_question_patterns",
    "open_follow_ups",
    "recent_sessions"
  ],
  "properties": {
    "summary_type": { "const": "learning_memory_summary" },
    "repo": { "type": "string" },
    "updated_at": { "type": "string" },
    "total_sessions": { "type": "integer" },
    "top_topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "count"],
        "properties": {
          "topic": { "type": "string" },
          "count": { "type": "integer" }
        }
      }
    },
    "top_intents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["intent", "count"],
        "properties": {
          "intent": { "type": "string" },
          "count": { "type": "integer" }
        }
      }
    },
    "top_learning_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["learning_point", "count", "weighted_count", "confidence"],
        "properties": {
          "learning_point": { "type": "string" },
          "count": { "type": "integer" },
          "weighted_count": { "type": "number" },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "repeated_learning_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["learning_point", "count", "weighted_count", "confidence"],
        "properties": {
          "learning_point": { "type": "string" },
          "count": { "type": "integer" },
          "weighted_count": { "type": "number" },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "learning_point_confidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["learning_point", "count", "weighted_count", "confidence"],
        "properties": {
          "learning_point": { "type": "string" },
          "count": { "type": "integer" },
          "weighted_count": { "type": "number" },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "top_reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reviewer", "count"],
        "properties": {
          "reviewer": { "type": "string" },
          "count": { "type": "integer" }
        }
      }
    },
    "recurring_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "count"],
        "properties": {
          "path": { "type": "string" },
          "count": { "type": "integer" }
        }
      }
    },
    "recent_questions": { "type": "array", "items": { "type": "string" } },
    "recent_learning_points": { "type": "array" },
    "repeated_question_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_fingerprint", "count"],
        "properties": {
          "question_fingerprint": { "type": "string" },
          "count": { "type": "integer" }
        }
      }
    },
    "open_follow_ups": { "type": "array", "items": { "type": "string" } },
    "recent_sessions": { "type": "array" },
    "weighted_learning_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["learning_point", "count", "weighted_count", "confidence"],
        "properties": {
          "learning_point": { "type": "string" },
          "count": { "type": "integer" },
          "weighted_count": { "type": "number" },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    }
  }
}
