{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MyPrContext",
  "type": "object",
  "required": [
    "repo",
    "repo_path",
    "repo_state_dir",
    "learner_profile",
    "db_path",
    "current_pr",
    "git_context",
    "suggested_topics",
    "topic_inference_reasons",
    "topic_candidates",
    "primary_intent",
    "suggested_intents",
    "intent_reasons",
    "intent_candidates",
    "reviewer_candidates",
    "reviewer_candidate_details",
    "recommended_next_actions",
    "agent_notes"
  ],
  "properties": {
    "context_type": { "type": "string" },
    "repo": { "type": "string" },
    "repo_path": { "type": "string" },
    "repo_state_dir": { "type": "string" },
    "learner_profile": { "type": "object" },
    "db_path": { "type": "string" },
    "current_pr": { "type": "object" },
    "git_context": { "type": "object" },
    "suggested_topics": { "type": "array", "items": { "type": "string" } },
    "topic_inference_reasons": { "type": "array", "items": { "type": "string" } },
    "topic_candidates": { "type": "array" },
    "primary_intent": { "type": "string" },
    "suggested_intents": { "type": "array", "items": { "type": "string" } },
    "intent_reasons": { "type": "array", "items": { "type": "string" } },
    "intent_candidates": { "type": "array" },
    "reviewer_candidates": { "type": "array", "items": { "type": "string" } },
    "reviewer_candidate_details": { "type": "array" },
    "pr_report_evidence": { "type": ["object", "null"] },
    "recommended_next_actions": { "type": "array", "items": { "type": "object" } },
    "agent_notes": { "type": "array", "items": { "type": "string" } },
    "json_path": { "type": "string" }
  }
}
