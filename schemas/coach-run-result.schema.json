{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoachRunResult",
  "type": "object",
  "required": [
    "run_type",
    "execution_status",
    "generated_at",
    "repo",
    "repo_resolution",
    "archive_sync",
    "archive_status",
    "session",
    "memory",
    "coach_reply"
  ],
  "properties": {
    "run_type": { "const": "coach_run" },
    "execution_status": { "enum": ["ready", "blocked", "error"] },
    "error_detail": {
      "type": "object",
      "properties": {
        "phase": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "sidecar_path": { "type": "string" }
      }
    },
    "canonical_write_failed": { "type": "boolean" },
    "generated_at": { "type": "string" },
    "repo": { "type": "string" },
    "repo_resolution": { "type": "object" },
    "archive_sync": { "type": "object" },
    "archive_status": {
      "type": "object",
      "required": ["bootstrap_state", "data_confidence"],
      "properties": {
        "bootstrap_state": {
          "enum": ["uninitialized", "bootstrapping", "ready"]
        },
        "data_confidence": {
          "enum": ["bootstrap", "partial", "ready"]
        },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "signals": { "type": "object" },
        "thresholds": { "type": "object" },
        "latest_run": {},
        "sync_status": { "type": "object" },
        "computed_at": { "type": "string" }
      }
    },
    "session": { "type": "object" },
    "memory": { "type": "object" },
    "coach_reply": {
      "type": "object",
      "required": ["memory_notes", "response", "markdown"],
      "properties": {
        "memory_notes": { "type": "array", "items": { "type": "string" } },
        "response": { "type": "object" },
        "markdown": { "type": "string" }
      }
    },
    "cs_readiness": {
      "type": "object",
      "description": "CS RAG index readiness, separate from execution_status. State≠ready means peer-only degrade, not blocked.",
      "required": ["state", "next_command", "reason"],
      "properties": {
        "state": { "enum": ["ready", "missing", "stale", "corrupt"] },
        "reason": { "type": ["string", "null"] },
        "corpus_hash": { "type": ["string", "null"] },
        "index_manifest_hash": { "type": ["string", "null"] },
        "next_command": { "type": ["string", "null"] }
      }
    },
    "cs_augmentation": {
      "type": ["object", "null"],
      "description": "Compact CS RAG search results. Source-of-truth for cs_block (which is a render view). Long bodies live in contexts/cs-augmentation.json sidecar.",
      "properties": {
        "by_learning_point": { "type": "object" },
        "by_fallback_key": { "type": "object" },
        "fallback_reason": { "type": ["string", "null"] },
        "cs_categories_hit": { "type": "array", "items": { "type": "string" } },
        "sidecar_path": { "type": ["string", "null"] },
        "verifier_hits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": ["string", "null"] },
              "title": { "type": ["string", "null"] }
            }
          }
        },
        "citation_paths": { "type": "array", "items": { "type": "string" } },
        "meta": {
          "type": "object",
          "properties": {
            "latency_ms": { "type": "integer", "minimum": 0 },
            "rag_ready": { "type": "boolean" },
            "reason": { "type": ["string", "null"] },
            "mode_used": { "enum": ["skip", "cheap", "full"] }
          }
        }
      }
    },
    "intent_decision": {
      "type": "object",
      "description": "Two-stage intent routing result. block_plan is advisory guidance for the AI session.",
      "required": ["detected_intent", "block_plan"],
      "properties": {
        "detected_intent": {
          "enum": [
            "mission_only", "cs_only", "mixed",
            "drill_answer", "mixed_with_drill_answer", "unknown"
          ]
        },
        "pre_intent": { "type": "string" },
        "cs_search_mode": { "enum": ["skip", "cheap", "full"] },
        "signals": { "type": "object" },
        "block_plan": {
          "type": "object",
          "required": ["snapshot_block", "cs_block", "verification", "drill_block"],
          "properties": {
            "snapshot_block": { "enum": ["primary", "supporting", "omit"] },
            "cs_block":       { "enum": ["primary", "supporting", "omit"] },
            "verification":   { "enum": ["primary", "supporting", "omit"] },
            "drill_block":    { "enum": ["primary", "supporting", "omit"] }
          }
        },
        "drill_in_turn": { "type": "object" }
      }
    },
    "unified_profile": {
      "type": ["object", "null"],
      "description": "Per-turn compact projection of memory/profile.json (Phase 3). Persisted truth lives in profile.json; this is a derived view."
    },
    "response_contract": {
      "type": "object",
      "required": ["snapshot_block", "verification"],
      "properties": {
        "cs_block": {
          "type": ["object", "null"],
          "description": "Render view of cs_augmentation. Not a source of truth — rebuild from cs_augmentation if drift suspected.",
          "properties": {
            "markdown": { "type": ["string", "null"] },
            "sources": { "type": "array" },
            "reason": { "type": ["string", "null"] },
            "applicability_hint": { "enum": ["primary", "supporting", "omit"] },
            "grounding_check": {
              "type": "object",
              "properties": {
                "ok": { "type": "boolean" },
                "ungrounded_paths": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "severity": { "enum": ["ok", "warn"] }
              }
            }
          }
        },
        "drill_block": {
          "type": ["object", "null"],
          "description": "Drill question offer for this turn (Phase 4). reason='none' until drill engine ships.",
          "properties": {
            "markdown": { "type": ["string", "null"] },
            "reason": { "type": ["string", "null"] },
            "applicability_hint": { "enum": ["primary", "supporting", "omit"] }
          }
        },
        "drill_result_block": {
          "type": ["object", "null"],
          "description": "Scoring of a drill answer routed in this turn (Phase 4)."
        },
        "cognitive_block": {
          "type": ["object", "null"],
          "description": "Single selected cognitive trigger for this turn. Optional view; source selection is runtime policy."
        },
        "follow_up_block": {
          "type": ["object", "null"],
          "description": "Legacy follow-up queue view. May be suppressed when cognitive_block surfaces a trigger."
        },
        "snapshot_block": {
          "type": "object",
          "required": [
            "markdown",
            "counts",
            "computed_at",
            "target_pr_number",
            "target_pr_selection_reason",
            "reason"
          ],
          "properties": {
            "markdown": { "type": ["string", "null"] },
            "computed_at": { "type": "string" },
            "target_pr_number": { "type": ["integer", "null"] },
            "target_pr_selection_reason": { "type": "string" },
            "reason": { "type": "string" },
            "counts": {
              "type": ["object", "null"],
              "required": ["total", "classification", "reply_axis"],
              "properties": {
                "total": { "type": "integer", "minimum": 0 },
                "classification": {
                  "type": "object",
                  "required": [
                    "still-applies",
                    "likely-fixed",
                    "already-fixed",
                    "ambiguous",
                    "unread"
                  ],
                  "properties": {
                    "still-applies": { "type": "integer", "minimum": 0 },
                    "likely-fixed": { "type": "integer", "minimum": 0 },
                    "already-fixed": { "type": "integer", "minimum": 0 },
                    "ambiguous": { "type": "integer", "minimum": 0 },
                    "unread": { "type": "integer", "minimum": 0 }
                  }
                },
                "reply_axis": {
                  "type": "object",
                  "required": ["text", "emoji", "none", "unknown"],
                  "properties": {
                    "text": { "type": "integer", "minimum": 0 },
                    "emoji": { "type": "integer", "minimum": 0 },
                    "none": { "type": "integer", "minimum": 0 },
                    "unknown": { "type": "integer", "minimum": 0 }
                  }
                }
              }
            }
          }
        },
        "verification": {
          "type": "object",
          "required": ["required_count", "thread_refs", "stub_markdown"],
          "properties": {
            "required_count": { "type": "integer", "minimum": 0 },
            "thread_refs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["thread_id", "path", "classification"],
                "properties": {
                  "thread_id": { "type": ["string", "integer"] },
                  "path": { "type": "string" },
                  "line": { "type": ["integer", "null"] },
                  "classification": {
                    "type": "string",
                    "enum": ["likely-fixed", "ambiguous"]
                  },
                  "classification_reason": { "type": ["string", "null"] }
                }
              }
            },
            "stub_markdown": { "type": ["string", "null"] }
          }
        }
      }
    },
    "json_path": { "type": "string" }
  }
}
